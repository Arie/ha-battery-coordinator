# Battery Coordinator Configuration
# Copy to .env and fill in your values

# === REQUIRED ===

# Zendure device IP (find in Zendure app → Device Information)
# HEMS must be disabled in the Zendure app for local API access
ZENDURE_IP=192.168.1.116

# HomeWizard P1 meter IP and API token
# Token from: HW app → Settings → Local API → API token
HW_P1_IP=192.168.1.148
HW_P1_TOKEN=your_token_here

# === OPTIONAL: Solar sensor via Home Assistant ===
# Without solar, the brain can't auto-detect sunrise (charge→discharge flip).
# It still works — just uses P1 signal only.

# HA_URL=http://192.168.1.9:8123
# HA_TOKEN=your_long_lived_access_token
# SOLAR_ENTITY=sensor.solaredge_se6k_ac_power

# === OPTIONAL: Hardware limits ===
# Defaults match Zendure 2400 AC. Change for other models.

# ZEN_MAX_CHARGE_W=2400
# ZEN_MAX_DISCHARGE_W=2400
# ZEN_SOC_MIN=10
# ZEN_SOC_MAX=100

# === OPTIONAL: Advanced brain tuning ===
# Production-tested defaults. Only change if you know what you're doing.
# All brain knobs use the BRAIN_* prefix; see PermissionFSM.DEFAULTS for
# the full list.

# BRAIN_STEP_HOLDOFF_S=15   # seconds before stepping Zendure up/down
# BRAIN_FLIP_S=30           # seconds before charge↔discharge flip
# BRAIN_PIB_HIGH_W=1200     # PIB power threshold for step-up
# BRAIN_NOM_DEADBAND_W=10   # minimum W change before sending in NOM mode
# LOG_LEVEL=INFO            # DEBUG for verbose output
